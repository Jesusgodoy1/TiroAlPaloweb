<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;700;900&family=Barlow:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { background: #0a0a0a; color: #fff; font-family: 'Barlow', sans-serif; }

  /* NAV */
  nav {
    background: #0a0a0a;
    border-bottom: 1px solid #1e1e1e;
    padding: 0 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .nav-logo {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 22px;
    letter-spacing: 1px;
    color: #fff;
    text-transform: uppercase;
  }
  .nav-logo span { color: #22c55e; }
  .nav-links { display: flex; gap: 1.5rem; }
  .nav-links a {
    color: #aaa;
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: #22c55e; }
  .nav-cta {
    background: #22c55e;
    color: #000 !important;
    padding: 6px 16px;
    border-radius: 4px;
    font-weight: 600 !important;
  }
  .nav-cta:hover { background: #16a34a; color: #000 !important; }

  /* HERO BANNER */
  .hero {
    background: #0a0a0a;
    min-height: 340px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    padding: 3rem 2rem;
    border-bottom: 2px solid #22c55e;
  }
  .hero-bg-num {
    position: absolute;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 400px;
    color: #ffffff08;
    line-height: 1;
    top: -60px;
    left: 50%;
    transform: translateX(-50%);
    user-select: none;
    pointer-events: none;
  }
  .hero-logo-area {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    position: relative;
    z-index: 2;
  }
  .logo-icon {
    font-size: 90px;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }
  .logo-icon .num1 {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 90px;
    color: #fff;
    line-height: 1;
  }
  .logo-icon .ball {
    font-size: 52px;
    position: absolute;
    right: -36px;
    top: 4px;
  }
  .hero-brand {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 64px;
    letter-spacing: 2px;
    text-transform: uppercase;
    line-height: 0.9;
    text-align: center;
  }
  .hero-brand .line2 {
    color: #22c55e;
    font-size: 44px;
    display: block;
  }
  .hero-sub {
    font-size: 15px;
    color: #888;
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-top: 0.5rem;
    font-weight: 500;
  }
  .hero-tags {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 1.5rem;
  }
  .tag {
    border: 1px solid #333;
    color: #aaa;
    padding: 5px 14px;
    border-radius: 20px;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 500;
  }
  .tag.green { border-color: #22c55e; color: #22c55e; }

  /* ENVIO BANNER */
  .envio-bar {
    background: #22c55e;
    color: #000;
    text-align: center;
    padding: 10px;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 16px;
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  /* SECCION TITULO */
  .section-header {
    padding: 3rem 2rem 1.5rem;
    max-width: 1100px;
    margin: 0 auto;
    width: 100%;
  }
  .section-header h2 {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 36px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .section-header h2 span { color: #22c55e; }
  .section-header p { color: #666; font-size: 14px; margin-top: 4px; }

  /* FILTROS */
  .filters {
    padding: 0 2rem 1.5rem;
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .filter-btn {
    background: transparent;
    border: 1px solid #2a2a2a;
    color: #888;
    padding: 6px 16px;
    border-radius: 4px;
    font-size: 13px;
    cursor: pointer;
    font-family: 'Barlow', sans-serif;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: all 0.2s;
  }
  .filter-btn:hover, .filter-btn.active {
    background: #22c55e;
    border-color: #22c55e;
    color: #000;
  }

  /* GRID CAMISETAS */
  .catalogo {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem 4rem;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.5rem;
  }
  .card {
    background: #111;
    border: 1px solid #1e1e1e;
    border-radius: 8px;
    overflow: hidden;
    transition: border-color 0.2s, transform 0.2s;
    cursor: pointer;
  }
  .card:hover {
    border-color: #22c55e;
    transform: translateY(-3px);
  }
  .card-img {
    background: #181818;
    height: 200px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  .card-img .placeholder-text {
    font-size: 52px;
    opacity: 0.15;
  }
  .card-img .coming {
    font-size: 11px;
    color: #444;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-top: 6px;
    font-weight: 500;
  }
  .card-img .badge {
    position: absolute;
    top: 10px;
    left: 10px;
    background: #22c55e;
    color: #000;
    font-size: 10px;
    font-weight: 700;
    padding: 3px 8px;
    border-radius: 3px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .card-img .badge.premium {
    background: #f59e0b;
  }
  .card-body { padding: 1rem; }
  .card-country {
    font-size: 11px;
    color: #22c55e;
    text-transform: uppercase;
    letter-spacing: 2px;
    font-weight: 600;
    margin-bottom: 4px;
  }
  .card-name {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 20px;
    text-transform: uppercase;
    line-height: 1.1;
    color: #fff;
  }
  .card-detail {
    font-size: 12px;
    color: #555;
    margin-top: 3px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .card-footer {
    padding: 0.75rem 1rem 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid #1e1e1e;
  }
  .card-price {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 26px;
    color: #fff;
  }
  .card-price span {
    font-size: 13px;
    color: #555;
    font-weight: 400;
    font-family: 'Barlow', sans-serif;
  }
  .btn-pedir {
    background: #22c55e;
    color: #000;
    border: none;
    padding: 7px 14px;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 700;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-family: 'Barlow', sans-serif;
    transition: background 0.2s;
  }
  .btn-pedir:hover { background: #16a34a; }

  /* TALLES */
  .talles {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
    padding: 0 1rem 0.75rem;
  }
  .talle {
    border: 1px solid #2a2a2a;
    color: #666;
    font-size: 10px;
    padding: 2px 7px;
    border-radius: 3px;
    font-weight: 600;
    text-transform: uppercase;
  }

  /* INFO SECTION */
  .info-section {
    background: #111;
    border-top: 1px solid #1e1e1e;
    border-bottom: 1px solid #1e1e1e;
    padding: 3rem 2rem;
  }
  .info-grid {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    text-align: center;
  }
  .info-item .ico {
    font-size: 36px;
    margin-bottom: 0.75rem;
    display: block;
  }
  .info-item h3 {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 18px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #fff;
    margin-bottom: 4px;
  }
  .info-item p { font-size: 13px; color: #555; line-height: 1.5; }

  /* CTA WHATSAPP */
  .cta-section {
    padding: 4rem 2rem;
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
  }
  .cta-section h2 {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 44px;
    text-transform: uppercase;
    line-height: 1;
    margin-bottom: 0.75rem;
  }
  .cta-section h2 em {
    color: #22c55e;
    font-style: normal;
  }
  .cta-section p { color: #666; font-size: 15px; margin-bottom: 2rem; }
  .btn-wa {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #25d366;
    color: #000;
    padding: 14px 32px;
    border-radius: 6px;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 20px;
    text-transform: uppercase;
    letter-spacing: 1px;
    text-decoration: none;
    cursor: pointer;
    border: none;
    transition: background 0.2s, transform 0.1s;
  }
  .btn-wa:hover { background: #1da851; transform: scale(1.02); }

  /* FOOTER */
  footer {
    border-top: 1px solid #1e1e1e;
    padding: 1.5rem 2rem;
    text-align: center;
    color: #333;
    font-size: 13px;
  }
  footer strong { color: #22c55e; }
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="nav-logo">Tiro <span>al Palo</span></div>
  <div class="nav-links">
    <a href="#">Selecciones</a>
    <a href="#">Clubes</a>
    <a href="#">Envíos</a>
    <a href="#" class="nav-cta">Pedir ya</a>
  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-bg-num">1</div>
  <div class="hero-logo-area">
    <div style="display:flex;align-items:center;gap:0.5rem;position:relative;">
      <span style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:88px;color:#fff;line-height:1;">1</span>
      <span style="font-size:54px;position:relative;top:-6px;">⚽</span>
    </div>
    <div class="hero-brand">
      TIRO AL PALO
      <span class="line2">Camisetas</span>
    </div>
    <div class="hero-sub">Calidad G5 · Precio para todos</div>
    <div class="hero-tags">
      <span class="tag green">⚡ Calidad Premium</span>
      <span class="tag">🌍 Clubes Europeos</span>
      <span class="tag">🏆 Selecciones</span>
      <span class="tag">🇦🇷 Envíos a todo el país</span>
    </div>
  </div>
</section>

<!-- BANNER ENVIO -->
<div class="envio-bar">
  📦 Envíos a todo el país · Todos los talles · $38.000 precio único
</div>

<!-- SECCION CATALOGO -->
<div class="section-header">
  <h2>Catálogo <span>disponible</span></h2>
  <p>Camisetas de jugador calidad G5 — las mismas que usan los pros</p>
</div>

<div class="filters">
  <button class="filter-btn active" onclick="setFilter(this,'todos')">Todos</button>
  <button class="filter-btn" onclick="setFilter(this,'seleccion')">Selecciones</button>
  <button class="filter-btn" onclick="setFilter(this,'europeo')">Clubes europeos</button>
  <button class="filter-btn" onclick="setFilter(this,'americano')">Clubes americanos</button>
</div>

<div class="catalogo" id="catalogo"></div>

<!-- INFO -->
<section class="info-section">
  <div class="info-grid">
    <div class="info-item">
      <span class="ico">👕</span>
      <h3>Calidad G5</h3>
      <p>La misma calidad que usa el jugador. Tela premium, bordados y detalles perfectos.</p>
    </div>
    <div class="info-item">
      <span class="ico">📦</span>
      <h3>Envíos al país</h3>
      <p>Mandamos a cualquier provincia de Argentina. Consulta por tiempos de entrega.</p>
    </div>
    <div class="info-item">
      <span class="ico">💰</span>
      <h3>$38.000</h3>
      <p>Precio único para todos los talles. Sin excusas para no tener tu camiseta.</p>
    </div>
    <div class="info-item">
      <span class="ico">📏</span>
      <h3>Todos los talles</h3>
      <p>Desde XS hasta XXL. Si necesitás algo especial, consultanos directamente.</p>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta-section">
  <h2>¿Querés tu <em>camiseta</em>?</h2>
  <p>Escribinos por WhatsApp, elegís el modelo, talle y listo. Enviamos a todo el país.</p>
  <button class="btn-wa" onclick="alert('¡Pronto activo! Configurá tu número de WhatsApp aquí.')">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
    Pedir por WhatsApp
  </button>
</section>

<!-- FOOTER -->
<footer>
  <strong>Tiro al Palo</strong> · Camisetas de fútbol premium · Envíos a todo el país · 2026
</footer>

<script>
const productos = [
  { id:1, pais:'Argentina', nombre:'Selección Argentina', detalle:'Camiseta de jugador · 2024', categoria:'seleccion', badge:'Más vendida', badgeType:'' },
  { id:2, pais:'España', nombre:'Real Madrid', detalle:'Camiseta local · 2024/25', categoria:'europeo', badge:'Premium', badgeType:'premium' },
  { id:3, pais:'Inglaterra', nombre:'Manchester City', detalle:'Camiseta local · 2024/25', categoria:'europeo', badge:'', badgeType:'' },
  { id:4, pais:'Francia', nombre:'PSG', detalle:'Camiseta local · 2024/25', categoria:'europeo', badge:'', badgeType:'' },
  { id:5, pais:'Brasil', nombre:'Selección Brasil', detalle:'Camiseta de jugador · 2024', categoria:'seleccion', badge:'', badgeType:'' },
  { id:6, pais:'Argentina', nombre:'River Plate', detalle:'Camiseta local · 2024', categoria:'americano', badge:'', badgeType:'' },
  { id:7, pais:'Argentina', nombre:'Boca Juniors', detalle:'Camiseta local · 2024', categoria:'americano', badge:'', badgeType:'' },
  { id:8, pais:'Alemania', nombre:'Bayern Munich', detalle:'Camiseta local · 2024/25', categoria:'europeo', badge:'', badgeType:'' },
];

const talles = ['XS','S','M','L','XL','XXL'];
let filtroActivo = 'todos';

function renderCatalogo(filter) {
  const contenedor = document.getElementById('catalogo');
  const filtrados = filter === 'todos' ? productos : productos.filter(p => p.categoria === filter);
  contenedor.innerHTML = filtrados.map(p => `
    <div class="card">
      <div class="card-img">
        ${p.badge ? `<div class="badge ${p.badgeType}">${p.badge}</div>` : ''}
        <span class="placeholder-text">👕</span>
        <span class="coming">Foto próximamente</span>
      </div>
      <div class="card-body">
        <div class="card-country">${p.pais}</div>
        <div class="card-name">${p.nombre}</div>
        <div class="card-detail">${p.detalle}</div>
      </div>
      <div class="talles">
        ${talles.map(t => `<span class="talle">${t}</span>`).join('')}
      </div>
      <div class="card-footer">
        <div class="card-price">$38.000 <span>c/u</span></div>
        <button class="btn-pedir" onclick="pedirCamiseta('${p.nombre}')">Pedir</button>
      </div>
    </div>
  `).join('');
}

function setFilter(btn, cat) {
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  filtroActivo = cat;
  renderCatalogo(cat);
}

function pedirCamiseta(nombre) {
  alert('¡Genial! Pronto podrás pedir ' + nombre + ' directo por WhatsApp. Configurá tu número en el código.');
}

renderCatalogo('todos');
</script>
</body>
</html>
